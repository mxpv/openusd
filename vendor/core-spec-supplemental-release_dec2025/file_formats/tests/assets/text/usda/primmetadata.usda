#usda 1.0


def FooBar "baz" (
    kind= "component"
    active = false
    displayName = "baaazzzz";
    payload = None
    payload = </foo>
    append payload = [</bar>, </foobar>];prepend payload=[</foo/bar>]
    references = </foo/bar/baz>;delete references = [
        @:this is, an ; asset ref@ (
            offset = 18.5
        )
    ];inherits=[</foo/bar/foo>, </foo/bar/baz>];
    specializes=None
    append references = [@simple_asset@</with/path>]
    references = None
    append payload = </bar/baz/foo>
    delete payload = [
        @this/is/an/asset/ref@  </foobar> (
            offset = 5.0
            scale = 0.5
        )
    ]
    payload = @@@a/triple/asset ref@@@ (
        scale = -2.0
    );
    append references = [@simple_asset@</with/different/path>(offset=4.0;customData={int[] myData = [4, 6, 7]})];'this will be the comment'


    
){
}