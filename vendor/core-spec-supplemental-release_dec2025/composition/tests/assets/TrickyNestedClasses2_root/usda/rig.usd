#usda 1.0

def Model "KiltRig" (
    inherits = </_class_ClothRig>
)
{
    over "rig"
    {
        def "KiltHemRig" (
            add references = @./ClothHemRig.usd@</ClothHemRig>
        )
        {
        }
    }
}

class Model "_class_ClothRig" (
    references = @./ClothRig.usd@</ClothRig>
)
{
}

